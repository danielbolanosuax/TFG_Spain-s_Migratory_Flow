# Datos crudos — demasiado grandes para GitHub
data/

# Entorno virtual
.venv/

# Logs
output/logs/

# Python
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/

# Variables de entorno
.env

# Excepción: datos estáticos de conectividad (vía Git LFS)
!data/conectividad/
!data/conectividad/setid/
!data/conectividad/setid/*.xlsx


# Añadir excepciones para las carpetas nuevas
echo "!data/fondo_monetario_internacional/" >> .gitignore
echo "!data/fondo_monetario_internacional/**" >> .gitignore
echo "!data/renta/" >> .gitignore
echo "!data/renta/**" >> .gitignore